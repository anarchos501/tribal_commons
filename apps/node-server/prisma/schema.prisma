generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tribe {
  id                            Int                      @id @default(autoincrement())
  name                          String
  locality                      String
  createdAt                     DateTime                 @default(now())
  deletedAt                     DateTime?

  memberships                   Membership[]
  projects                      Project[]
  supportRequests               SupportRequest[]
  commonsPools                  CommonsPool[]
  governanceTopics              GovernanceTopic[]
  petitions                     Petition[]                 @relation("PetitionContextTribe")
  targetFederationPetitions      Petition[]                 @relation("PetitionTargetTribe")

  sourceFederationRelationships FederationRelationship[] @relation("SourceFederationRelationships")
  targetFederationRelationships FederationRelationship[] @relation("TargetFederationRelationships")
}

model Membership {
  id                 Int               @id @default(autoincrement())
  role               String

  tribeId            Int
  tribe              Tribe             @relation(fields: [tribeId], references: [id])

  characterProfileId Int?
  characterProfile   CharacterProfile? @relation(fields: [characterProfileId], references: [id])

  createdAt          DateTime          @default(now())
}

model Project {
  id              Int              @id @default(autoincrement())
  title           String
  status          String
  createdAt       DateTime         @default(now())

  tribeId         Int
  tribe           Tribe            @relation(fields: [tribeId], references: [id])

  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  archivedAt      DateTime?

  petitions       Petition[]
  contributions   Contribution[]
  supportRequests SupportRequest[]
  memberships     ProjectMembership[]
  actions         ProjectAction[]
  governanceTopics GovernanceTopic[]
}

model SupportRequest {
  id                   Int               @id @default(autoincrement())

  requesterName        String
  title                String
  description          String
  resourceType         String
  amountRequested      Int
  supportType          String
  status               String            @default("open")
  createdAt            DateTime          @default(now())

  tribeId              Int?
  tribe                Tribe?            @relation(fields: [tribeId], references: [id])

  requesterCharacterId Int?
  requesterCharacter   CharacterProfile? @relation(fields: [requesterCharacterId], references: [id])

  projectId            Int?
  project              Project?          @relation(fields: [projectId], references: [id])

  contributions        Contribution[]
}

model Petition {
  id                   Int               @id @default(autoincrement())
  type                 String
  title                String
  description          String
  status               String            @default("open")
  proposerName         String
  metadata             Json?
  publishAt            DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  tribeId              Int
  tribe                Tribe             @relation("PetitionContextTribe", fields: [tribeId], references: [id])

  projectId            Int?
  project              Project?          @relation(fields: [projectId], references: [id])

  targetTribeId        Int?
  targetTribe          Tribe?            @relation("PetitionTargetTribe", fields: [targetTribeId], references: [id])

  proposerCharacterId  Int?
  proposerCharacter    CharacterProfile? @relation("PetitionsProposed", fields: [proposerCharacterId], references: [id])

  sponsors             PetitionSponsor[]
  supports             PetitionSupport[]
  sponsorRequests      PetitionSponsorRequest[]
  governanceTopics     GovernanceTopic[]
}

model PetitionSponsor {
  id                   Int               @id @default(autoincrement())
  sponsorName          String
  createdAt            DateTime          @default(now())
  removedAt            DateTime?

  petitionId           Int
  petition             Petition          @relation(fields: [petitionId], references: [id])

  sponsorCharacterId   Int?
  sponsorCharacter     CharacterProfile? @relation(fields: [sponsorCharacterId], references: [id])

  @@unique([petitionId, sponsorName])
}

model PetitionSponsorRequest {
  id                   Int               @id @default(autoincrement())
  requestType          String
  status               String            @default("pending")
  requesterName        String
  recipientName        String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  petitionId           Int
  petition             Petition          @relation(fields: [petitionId], references: [id])

  requesterCharacterId Int?
  requesterCharacter   CharacterProfile? @relation("SponsorRequestsMade", fields: [requesterCharacterId], references: [id])

  recipientCharacterId Int?
  recipientCharacter   CharacterProfile? @relation("SponsorRequestsReceived", fields: [recipientCharacterId], references: [id])

  preferences          PetitionSponsorRequestPreference[]

  @@unique([petitionId, requestType, requesterName, recipientName])
}

model PetitionSponsorRequestPreference {
  id                    Int                    @id @default(autoincrement())
  value                 Int
  voterName             String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  sponsorRequestId      Int
  sponsorRequest        PetitionSponsorRequest @relation(fields: [sponsorRequestId], references: [id])

  voterCharacterId      Int?
  voterCharacter        CharacterProfile?      @relation(fields: [voterCharacterId], references: [id])

  @@unique([sponsorRequestId, voterName])
}

model PetitionSupport {
  id                   Int               @id @default(autoincrement())
  supporterName        String
  createdAt            DateTime          @default(now())

  petitionId           Int
  petition             Petition          @relation(fields: [petitionId], references: [id])

  supporterCharacterId Int?
  supporterCharacter   CharacterProfile? @relation(fields: [supporterCharacterId], references: [id])

  @@unique([petitionId, supporterName])
}

model ProjectMembership {
  id                 Int               @id @default(autoincrement())
  memberName         String
  role               String            @default("member")
  createdAt          DateTime          @default(now())
  removedAt          DateTime?

  projectId          Int
  project            Project           @relation(fields: [projectId], references: [id])

  characterProfileId Int?
  characterProfile   CharacterProfile? @relation(fields: [characterProfileId], references: [id])

  @@unique([projectId, memberName])
}

model ProjectAction {
  id                  Int                    @id @default(autoincrement())
  title               String
  description         String
  actionType          String
  status              String                 @default("open")
  proposerName        String
  resourceType        String?
  amount              Int?
  resourceNote        String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  acceptedAt          DateTime?
  archivedAt          DateTime?

  projectId           Int
  project             Project                @relation(fields: [projectId], references: [id])

  proposerCharacterId Int?
  proposerCharacter   CharacterProfile?      @relation("ProjectActionsProposed", fields: [proposerCharacterId], references: [id])

  supports            ProjectActionSupport[]
}

model ProjectActionSupport {
  id                   Int               @id @default(autoincrement())
  supporterName        String
  createdAt            DateTime          @default(now())

  actionId             Int
  action               ProjectAction     @relation(fields: [actionId], references: [id])

  supporterCharacterId Int?
  supporterCharacter   CharacterProfile? @relation(fields: [supporterCharacterId], references: [id])

  @@unique([actionId, supporterName])
}

model CommonsPool {
  id            Int            @id @default(autoincrement())
  name          String
  description   String
  createdAt     DateTime       @default(now())
  deletedAt     DateTime?

  tribeId       Int
  tribe         Tribe          @relation(fields: [tribeId], references: [id])

  contributions Contribution[]
}

model Contribution {
  id                     Int               @id @default(autoincrement())

  contributorName             String
  resourceType           String
  amount                 Int
  createdAt              DateTime          @default(now())

  projectId              Int?
  project                Project?          @relation(fields: [projectId], references: [id])

  supportRequestId       Int?
  supportRequest         SupportRequest?   @relation(fields: [supportRequestId], references: [id])

  commonsPoolId          Int?
  commonsPool            CommonsPool?      @relation(fields: [commonsPoolId], references: [id])

  contributorCharacterId Int?
  contributorCharacter   CharacterProfile? @relation(fields: [contributorCharacterId], references: [id])
}

model PersonalStanding {
  id                   Int               @id @default(autoincrement())

  observerName         String
  subjectType          String
  subjectName          String
  tribeContextId       Int?
  value                Int
  note                 String?

  visibility           String            @default("private")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  observerCharacterId  Int?
  observerCharacter    CharacterProfile? @relation("ObserverStandings", fields: [observerCharacterId], references: [id])

  subjectCharacterId   Int?
  subjectCharacter     CharacterProfile? @relation("SubjectStandings", fields: [subjectCharacterId], references: [id])
}

model GovernanceTopic {
  id          Int      @id @default(autoincrement())
  tribeId     Int
  projectId   Int?
  petitionId  Int?
  scope       String   @default("tribe")
  key         String
  title       String
  description String
  minLabel    String
  maxLabel    String
  createdAt   DateTime @default(now())

  tribe       Tribe    @relation(fields: [tribeId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  petition    Petition? @relation(fields: [petitionId], references: [id])

  preferences GovernancePreference[]
}

model GovernancePreference {
  id                  Int               @id @default(autoincrement())
  topicId             Int
  memberName          String
  value               Int
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  topic               GovernanceTopic   @relation(fields: [topicId], references: [id])

  memberCharacterId   Int?
  memberCharacter     CharacterProfile? @relation(fields: [memberCharacterId], references: [id])

  @@unique([topicId, memberName])
}

model FederationRelationship {
  id               Int      @id @default(autoincrement())

  sourceTribeId    Int
  sourceTribe      Tribe    @relation("SourceFederationRelationships", fields: [sourceTribeId], references: [id])

  targetTribeId    Int
  targetTribe      Tribe    @relation("TargetFederationRelationships", fields: [targetTribeId], references: [id])

  relationshipType String
  note             String?

  createdAt        DateTime @default(now())
}

model ActivityEvent {
  id               Int               @id @default(autoincrement())

  type             String
  title            String
  message          String

  entityType       String?
  entityId         Int?

  tribeId          Int?
  actorName        String?

  actorCharacterId Int?
  actorCharacter   CharacterProfile? @relation(fields: [actorCharacterId], references: [id])

  visibleToCharacterIds Int[]            @default([])

  createdAt        DateTime          @default(now())
}

model UserAccount {
  id          Int      @id @default(autoincrement())
  username String @unique
  email       String?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  characters  CharacterProfile[]
}

model CharacterProfile {
  id                     Int                    @id @default(autoincrement())
  userAccountId           Int
  characterName           String
  frontierWalletAddress   String?
  frontierCharacterId     String?
  verified                Boolean                @default(false)
  createdAt               DateTime               @default(now())
  deletedAt               DateTime?

  userAccount             UserAccount            @relation(fields: [userAccountId], references: [id])

  memberships             Membership[]
  supportRequests         SupportRequest[]
  contributions           Contribution[]
  petitionsProposed       Petition[]              @relation("PetitionsProposed")
  petitionSponsors        PetitionSponsor[]
  sponsorRequestsMade     PetitionSponsorRequest[] @relation("SponsorRequestsMade")
  sponsorRequestsReceived PetitionSponsorRequest[] @relation("SponsorRequestsReceived")
  sponsorRequestPreferences PetitionSponsorRequestPreference[]
  petitionSupports        PetitionSupport[]
  projectMemberships      ProjectMembership[]
  projectActionsProposed  ProjectAction[]         @relation("ProjectActionsProposed")
  projectActionSupports   ProjectActionSupport[]
  governancePreferences   GovernancePreference[]

  standingsGiven          PersonalStanding[]     @relation("ObserverStandings")
  standingsReceived       PersonalStanding[]     @relation("SubjectStandings")

  activityEvents          ActivityEvent[]
}
