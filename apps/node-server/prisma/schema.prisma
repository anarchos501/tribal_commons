generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tribe {
  id         Int          @id @default(autoincrement())
  name       String
  locality   String
  createdAt  DateTime     @default(now())

  memberships Membership[]
  projects    Project[]
  aidRequests AidRequest[]
  commonsPools CommonsPool[]
}

model Membership {
  id        Int      @id @default(autoincrement())
  role      String

  tribeId   Int
  tribe     Tribe    @relation(fields: [tribeId], references: [id])

  createdAt DateTime @default(now())
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  status      String
  createdAt   DateTime @default(now())

  tribeId     Int
  tribe       Tribe    @relation(fields: [tribeId], references: [id])

  petitions Petition[]
  donations Donation[]
}

model AidRequest {
  id              Int      @id @default(autoincrement())
  tribeId         Int
  requesterName   String
  title           String
  description     String
  resourceType    String
  amountRequested Int
  supportType     String
  status          String   @default("open")
  createdAt       DateTime @default(now())

  tribe           Tribe    @relation(fields: [tribeId], references: [id])
}

model Petition {
  id        Int      @id @default(autoincrement())
  signer    String
  createdAt DateTime @default(now())

  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
}

model CommonsPool {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  createdAt   DateTime @default(now())

  tribeId     Int
  tribe       Tribe    @relation(fields: [tribeId], references: [id])
}

model Donation {
  id           Int      @id @default(autoincrement())
  playerName   String
  resourceType String
  amount       Int
  createdAt    DateTime @default(now())

  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id])
}