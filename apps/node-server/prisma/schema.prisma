generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tribe {
  id                            Int                      @id @default(autoincrement())
  name                          String
  locality                      String
  createdAt                     DateTime                 @default(now())
  deletedAt                     DateTime?

  memberships                   Membership[]
  projects                      Project[]
  supportRequests               SupportRequest[]
  commonsPools                  CommonsPool[]
  governanceTopics              GovernanceTopic[]

  sourceFederationRelationships FederationRelationship[] @relation("SourceFederationRelationships")
  targetFederationRelationships FederationRelationship[] @relation("TargetFederationRelationships")
}

model Membership {
  id                 Int               @id @default(autoincrement())
  role               String

  tribeId            Int
  tribe              Tribe             @relation(fields: [tribeId], references: [id])

  characterProfileId Int?
  characterProfile   CharacterProfile? @relation(fields: [characterProfileId], references: [id])

  createdAt          DateTime          @default(now())
}

model Project {
  id              Int              @id @default(autoincrement())
  title           String
  status          String
  createdAt       DateTime         @default(now())

  tribeId         Int
  tribe           Tribe            @relation(fields: [tribeId], references: [id])

  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  archivedAt      DateTime?

  petitions       Petition[]
  contributions   Contribution[]
  supportRequests SupportRequest[]
}

model SupportRequest {
  id                   Int               @id @default(autoincrement())

  requesterName        String
  title                String
  description          String
  resourceType         String
  amountRequested      Int
  supportType          String
  status               String            @default("open")
  createdAt            DateTime          @default(now())

  tribeId              Int?
  tribe                Tribe?            @relation(fields: [tribeId], references: [id])

  requesterCharacterId Int?
  requesterCharacter   CharacterProfile? @relation(fields: [requesterCharacterId], references: [id])

  projectId            Int?
  project              Project?          @relation(fields: [projectId], references: [id])

  contributions        Contribution[]
}

model Petition {
  id                  Int               @id @default(autoincrement())
  signer              String
  createdAt           DateTime          @default(now())

  projectId           Int
  project             Project           @relation(fields: [projectId], references: [id])

  signerCharacterId   Int?
  signerCharacter     CharacterProfile? @relation(fields: [signerCharacterId], references: [id])
}

model CommonsPool {
  id            Int            @id @default(autoincrement())
  name          String
  description   String
  createdAt     DateTime       @default(now())
  deletedAt     DateTime?

  tribeId       Int
  tribe         Tribe          @relation(fields: [tribeId], references: [id])

  contributions Contribution[]
}

model Contribution {
  id                     Int               @id @default(autoincrement())

  contributorName             String
  resourceType           String
  amount                 Int
  createdAt              DateTime          @default(now())

  projectId              Int?
  project                Project?          @relation(fields: [projectId], references: [id])

  supportRequestId       Int?
  supportRequest         SupportRequest?   @relation(fields: [supportRequestId], references: [id])

  commonsPoolId          Int?
  commonsPool            CommonsPool?      @relation(fields: [commonsPoolId], references: [id])

  contributorCharacterId Int?
  contributorCharacter   CharacterProfile? @relation(fields: [contributorCharacterId], references: [id])
}

model PersonalStanding {
  id                   Int               @id @default(autoincrement())

  observerName         String
  subjectType          String
  subjectName          String
  tribeContextId       Int?
  value                Int
  note                 String?

  visibility           String            @default("private")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  observerCharacterId  Int?
  observerCharacter    CharacterProfile? @relation("ObserverStandings", fields: [observerCharacterId], references: [id])

  subjectCharacterId   Int?
  subjectCharacter     CharacterProfile? @relation("SubjectStandings", fields: [subjectCharacterId], references: [id])
}

model GovernanceTopic {
  id          Int      @id @default(autoincrement())
  tribeId     Int
  key         String
  title       String
  description String
  minLabel    String
  maxLabel    String
  createdAt   DateTime @default(now())

  tribe       Tribe    @relation(fields: [tribeId], references: [id])

  preferences GovernancePreference[]
}

model GovernancePreference {
  id                  Int               @id @default(autoincrement())
  topicId             Int
  memberName          String
  value               Int
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  topic               GovernanceTopic   @relation(fields: [topicId], references: [id])

  memberCharacterId   Int?
  memberCharacter     CharacterProfile? @relation(fields: [memberCharacterId], references: [id])

  @@unique([topicId, memberName])
}

model FederationRelationship {
  id               Int      @id @default(autoincrement())

  sourceTribeId    Int
  sourceTribe      Tribe    @relation("SourceFederationRelationships", fields: [sourceTribeId], references: [id])

  targetTribeId    Int
  targetTribe      Tribe    @relation("TargetFederationRelationships", fields: [targetTribeId], references: [id])

  relationshipType String
  note             String?

  createdAt        DateTime @default(now())
}

model ActivityEvent {
  id               Int               @id @default(autoincrement())

  type             String
  title            String
  message          String

  entityType       String?
  entityId         Int?

  tribeId          Int?
  actorName        String?

  actorCharacterId Int?
  actorCharacter   CharacterProfile? @relation(fields: [actorCharacterId], references: [id])

  createdAt        DateTime          @default(now())
}

model UserAccount {
  id          Int      @id @default(autoincrement())
  username String @unique
  email       String?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  characters  CharacterProfile[]
}

model CharacterProfile {
  id                     Int                    @id @default(autoincrement())
  userAccountId           Int
  characterName           String
  frontierWalletAddress   String?
  frontierCharacterId     String?
  verified                Boolean                @default(false)
  createdAt               DateTime               @default(now())
  deletedAt               DateTime?

  userAccount             UserAccount            @relation(fields: [userAccountId], references: [id])

  memberships             Membership[]
  supportRequests         SupportRequest[]
  contributions           Contribution[]
  petitions               Petition[]
  governancePreferences   GovernancePreference[]

  standingsGiven          PersonalStanding[]     @relation("ObserverStandings")
  standingsReceived       PersonalStanding[]     @relation("SubjectStandings")

  activityEvents          ActivityEvent[]
}